# ============================================
# ระบบจัดการสมาชิกร้านหนังสือ — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to git

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="ระบบจัดการสมาชิกร้านหนังสือ"

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Server only, never expose to client

# --- Bookstore Config ---
POINTS_REDEMPTION_RATE=5
DEFAULT_LOW_STOCK_THRESHOLD=5

# --- Email (Resend) ---
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@yourdomain.com
